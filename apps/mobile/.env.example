# VITNESS mobile — environment
#
# Copy to `.env` and fill in for a hosted backend. With these unset, the app
# falls back to the local Supabase stack (http://127.0.0.1:54321) — see
# app.config.ts. Only EXPO_PUBLIC_ vars reach the client bundle; never put the
# service-role key here.

# Hosted Supabase project URL, e.g. https://abcdefgh.supabase.co
EXPO_PUBLIC_SUPABASE_URL=

# Project "anon" public key (Settings → API). Safe to ship in the client.
EXPO_PUBLIC_SUPABASE_ANON_KEY=

# How many demo packs to grant a fresh anonymous session (optional, default 20).
EXPO_PUBLIC_MOCK_PACK_COUNT=20
