{
  "name": "vitness",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "VITNESS — second-screen World Cup companion: 2D play reconstructions, who-was-in-the-play trivia, and a sticker album you earn by watching.",
  "scripts": {
    "mobile": "pnpm --filter mobile start",
    "export:web": "pnpm --filter mobile export:web",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "test": "vitest run",
    "replay": "node supabase/seed/replay/run-replay.ts"
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": ">=22"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "supabase"
    ]
  },
  "devDependencies": {
    "supabase": "^2.106.0",
    "vitest": "^4.1.0",
    "@supabase/supabase-js": "^2.47.0"
  }
}
